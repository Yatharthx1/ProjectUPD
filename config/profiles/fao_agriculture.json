      }
    },

    "Mercury": {
      "layer":     "hard_gate",
      "direction": "up_bad",
      "relaxable": false,
      "impact":    "crop_soil_livestock_toxicity",
      "unit":      "mg/L",
      "weight":    0,
      "limits": {
        "acceptable": 0.002
      }
    },

    "Selenium": {
      "layer":     "hard_gate",
      "direction": "up_bad",
      "relaxable": false,
