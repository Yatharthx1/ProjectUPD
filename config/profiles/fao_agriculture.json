{
  "profile_id": "fao_agriculture",
  "name": "FAO Agricultural Water Quality",
  "standard": "FAO Irrigation Water Quality Guidelines — Ayers & Westcot (1985); FAO Animal Production & Health Paper 68",
  "version": "1.1",
  "use_case": "agriculture",

  "_notes": {
    "SAR":        "Derived metric. Auto-computed from Na/Ca/Mg by derived_metrics.py if not passed directly. Formula: Na / sqrt((Ca+Mg)/2), all in meq/L.",
    "EC":         "Primary salinity indicator. FAO restriction: <0.7 none, 0.7–3.0 slight/moderate, >3.0 severe. Non-relaxable — breach → NON_COMPLIANT.",
    "hard_gates": "Heavy metals (As, Cd, Pb, Hg, Se) — breach → UNSAFE, no WQI computed.",
    "dual_use":   "Profile targets irrigation. Livestock thresholds differ for TDS/Chloride/Nitrate — stored in livestock_limits for reference; runtime use_case routing to be added."
  },

  "parameters": {

    "pH": {
      "layer":     "non_relaxable",
      "direction": "both_bad",
      "relaxable": false,
      "impact":    "soil_chemistry_corrosion",
      "unit":      "pH units",
      "weight":    0,
      "limits": {
        "ideal":      [6.5, 7.5],
        "acceptable": [6.0, 8.4]
      }
    },

    "EC": {
      "layer":     "non_relaxable",
      "direction": "up_bad",
      "relaxable": false,
      "impact":    "salinity_hazard",
      "unit":      "dS/m",
      "weight":    0,
      "limits": {
        "ideal":      0.3,
        "acceptable": 0.7
      }
    },

    "SAR": {
      "layer":     "non_relaxable",
      "direction": "up_bad",
      "relaxable": false,
      "impact":    "sodium_permeability_hazard",
      "unit":      "dimensionless",
      "weight":    0,
      "derived":   true,
      "derived_from": ["Na", "Ca", "Mg"],
      "limits": {
        "ideal":      1.0,
        "acceptable": 3.0
      }
    },

    "TDS": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "salinity_osmotic_stress",
      "unit":      "mg/L",
      "weight":    0.10,
      "limits": {
        "ideal":       450,
        "acceptable":  1000,
        "permissible": 2000
      },
      "livestock_limits": {
        "ideal":       1000,
        "acceptable":  3000,
        "permissible": 7000
      }
    },

    "Boron": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "specific_ion_toxicity",
      "unit":      "mg/L",
      "weight":    0.10,
      "limits": {
        "ideal":       0.3,
        "acceptable":  0.7,
        "permissible": 3.0
      }
    },

    "Chloride": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "specific_ion_toxicity",
      "unit":      "mg/L",
      "weight":    0.10,
      "limits": {
        "ideal":       71,
        "acceptable":  142,
        "permissible": 355
      },
      "livestock_limits": {
        "ideal":       400,
        "acceptable":  1500,
        "permissible": 3000
      }
    },

    "Sodium": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "specific_ion_toxicity",
      "unit":      "mg/L",
      "weight":    0.10,
      "limits": {
        "ideal":       35,
        "acceptable":  69,
        "permissible": 207
      }
    },

    "Nitrate_N": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "excessive_vegetative_growth",
      "unit":      "mg/L as N",
      "weight":    0.08,
      "limits": {
        "ideal":       2,
        "acceptable":  5,
        "permissible": 30
      },
      "livestock_limits": {
        "ideal":       20,
        "acceptable":  44,
        "permissible": 100
      }
    },

    "Bicarbonate": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "permeability_adj_sar",
      "unit":      "mg/L",
      "weight":    0.08,
      "limits": {
        "ideal":       30,
        "acceptable":  90,
        "permissible": 518
      }
    },

    "Sulfate": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "soil_permeability",
      "unit":      "mg/L",
      "weight":    0.06,
      "limits": {
        "ideal":       100,
        "acceptable":  500,
        "permissible": 1000
      }
    },

    "Iron": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "plugging_staining",
      "unit":      "mg/L",
      "weight":    0.05,
      "limits": {
