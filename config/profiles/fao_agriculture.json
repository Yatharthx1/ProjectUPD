      "weight":    0.04,
      "limits": {
        "ideal":       0.05,
        "acceptable":  0.2,
        "permissible": 1.5
      }
    },

    "Zinc": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "phytotoxicity",
      "unit":      "mg/L",
      "weight":    0.04,
      "limits": {
        "ideal":       0.2,
        "acceptable":  1.0,
        "permissible": 5.0
      }
    },

    "Copper": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "phytotoxicity",
      "unit":      "mg/L",
      "weight":    0.03,
      "limits": {
        "ideal":       0.01,
        "acceptable":  0.05,
        "permissible": 0.2
      }
    },

    "Fluoride": {
      "layer":     "relaxable",
      "direction": "up_bad",
      "relaxable": true,
      "impact":    "fluorosis_livestock",
      "unit":      "mg/L",
      "weight":    0.04,
      "limits": {
        "ideal":       0.5,
        "acceptable":  1.0,
        "permissible": 2.0
      }
    },

    "Arsenic": {
      "layer":     "hard_gate",
      "direction": "up_bad",
      "relaxable": false,
      "impact":    "crop_toxicity_soil_accumulation",
      "unit":      "mg/L",
      "weight":    0,
      "limits": {
        "acceptable": 0.1
      }
    },

    "Cadmium": {
      "layer":     "hard_gate",
      "direction": "up_bad",
      "relaxable": false,
      "impact":    "soil_accumulation_food_chain",
      "unit":      "mg/L",
      "weight":    0,
      "limits": {
