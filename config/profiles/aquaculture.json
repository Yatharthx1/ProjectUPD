{
  "profile_id": "aquaculture",
  "name": "Aquaculture Water Quality",
  "standard": "FAO/NACA Aquaculture Guidelines; Boyd (1990) Water Quality in Ponds for Aquaculture; USEPA Aquatic Life Criteria",
  "version": "1.0",
  "use_case": "aquaculture",

  "_notes": {
    "primary_target":   "Freshwater fish (general). Marine and shrimp limits stored as marine_limits / shrimp_limits where they differ significantly.",
    "DO":               "Most critical parameter. Fish suffocate below 3 mg/L. Breach zone (qi > 100) provides steep penalty without a hard_gate, matching real-world hypoxia risk curve.",
    "Ammonia_N":        "Un-ionized NH3 (not total ammonia). Toxicity is species- and pH-dependent. Hard gate at 0.02 mg/L covers sensitive species.",
    "H2S":              "Hydrogen sulfide. Produced in anoxic sediments. Extremely toxic even at trace levels.",
    "Chlorine":         "Free residual chlorine. Lethal to fish gills at very low concentrations.",
    "Temperature":      "Both_bad: too cold stresses metabolism, too hot depletes DO and accelerates disease. Limits are for tropical/subtropical freshwater species.",
    "hard_gates":       "Ammonia_N, Nitrite, H2S, Chlorine, Copper, Zinc, Mercury, Arsenic, Lead — any breach → UNSAFE.",
    "marine_limits":    "Where present, these replace primary limits for marine or brackish systems."
  },

  "parameters": {

    "pH": {
      "layer":     "non_relaxable",
      "direction": "both_bad",
      "relaxable": false,
      "impact":    "physiological_stress_gill_damage",
      "unit":      "pH units",
      "weight":    0,
      "limits": {
        "ideal":      [7.0, 8.0],
        "acceptable": [6.5, 9.0]
      },
      "marine_limits": {
        "ideal":      [7.8, 8.3],
        "acceptable": [7.5, 8.5]
      }
    },

    "DO": {
      "layer":     "relaxable",
      "direction": "down_bad",
      "relaxable": true,
      "impact":    "hypoxia_fish_mortality",
      "unit":      "mg/L",
      "weight":    0.25,
      "limits": {
        "ideal":       10.0,
        "acceptable":  5.0,
        "permissible": 3.0
      }
    },

    "Ammonia_N": {
      "layer":     "hard_gate",
