{
  "profile_id": "industrial",
  "name": "Industrial Water Quality",
  "standard": "WHO Guidelines for Industrial Water Use; BIS IS:2490; General Engineering Standards for Boiler/Cooling/Process Water",
  "version": "1.0",
  "use_case": "industrial",

  "_notes": {
    "primary_target":   "Boiler feed water (strictest limits). Cooling and process water thresholds stored as cooling_limits / process_limits for future use_case routing.",
    "DO_boiler":        "Dissolved oxygen is UP_BAD for boilers — oxygen causes electrochemical corrosion of steel boiler tubes. Opposite of drinking water / aquaculture.",
    "pH_boiler":        "Alkaline pH (8.5–9.5) maintained deliberately for boiler systems to suppress corrosion. Cooling water uses a wider neutral-alkaline range.",
    "Hardness":         "Scale formation critical in boilers — even 1°F hardness causes deposits at high pressures. Hard_gate at 50 mg/L. Cooling water is less strict.",
    "Silica":           "Silica deposits on turbine blades at high temperatures. Very low hard_gate for high-pressure boilers.",
    "hard_gates":       "TDS, Hardness, Silica, Iron, DO, Copper, Arsenic, Lead, Mercury — any breach → UNSAFE (boiler context).",
    "cooling_limits":   "Where present, cooling_limits hold thresholds for open/closed cooling tower systems.",
    "process_limits":   "Where present, process_limits hold general process water thresholds (food-grade process water needs drinking water standards)."
  },

  "parameters": {

    "pH": {
      "layer":     "non_relaxable",
      "direction": "both_bad",
      "relaxable": false,
      "impact":    "corrosion_scale",
      "unit":      "pH units",
      "weight":    0,
      "limits": {
        "ideal":      [8.5, 9.5],
        "acceptable": [8.0, 10.5]
      },
      "cooling_limits": {
        "ideal":      [7.0, 8.5],
        "acceptable": [6.5, 9.0]
      },
